*.tar.bz2
*.tar.xz
*.tar.zst

# System
.DS_Store
Thumbs.db

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# JavaScript/Node specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*
node_modules/
jspm_packages/
